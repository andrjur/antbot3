    },
    {
      "parameters": {
        "jsCode": "const item = $input.first();\nif (!item || !item.binary || !item.binary.data) return[];\n\nconst binaryData = item.binary.data;\nconst mimeType = item.binary.mimeType || 'image/jpeg';\n\nitem.json.base64_image = binaryData;\nitem.json.mime_type = mimeType;\nitem.json.file_type = 'image';\n\nreturn [item];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position":[ 2144, 2304 ],
      "id": "0d6e7e33-bff3-4e95-8311-a84905f31ad5",
      "name": "Process Photo"
    },
    {
      "parameters": {
        "jsCode": "const item = $input.first();\nif (!item || !item.binary || !item.binary.data) return[];\n\nconst binaryData = item.binary.data;\nconst mimeType = item.binary.mimeType || 'audio/ogg';\nconst fileSize = binaryData.length || 0;\n\nif (fileSize > 10 * 1024 * 1024) {\n  item.json.audio_warning = `Аудио слишком большое. ИИ обработает только часть.`;\n}\n\nitem.json.audio_data = binaryData;\nitem.json.file_type = 'audio';\nitem.json.mime_type = mimeType;\n\nreturn [item];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position":[ 2144, 2480 ],
      "id": "8941124f-dc96-4391-9d4b-da824f8671e1",
      "name": "Process Audio"
    },
    {
      "parameters": {
        "jsCode": "const item = $input.first();\nif (!item || !item.binary || !item.binary.data) return[];\n\nconst binaryData = item.binary.data;\nconst mimeType = item.binary.mimeType || 'video/ogg';\nconst fileSize = binaryData.length || 0;\n\nif (fileSize > 10 * 1024 * 1024) {\n  item.json.file_warning = `Файл слишком большой.`;\n}\n\nitem.json.audio_data = binaryData;\nitem.json.file_type = 'video';\nitem.json.mime_type = mimeType;\n\nreturn [item];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position":[ 2144, 2640 ],
      "id": "c57cc78c-1e4f-4c4d-ac26-0868e115625a",
      "name": "Process Video"
    },
    {
      "parameters": {
        "jsCode": "const hwText = $input.first().json.hw_text || $('Edit Fields').first().json.hw_text || '[Текст отсутствует]';\nconst audioWarning = $input.first().json.audio_warning || '';\nconst base64Image = $input.first().json.base64_image || null;\nconst mimeType = $input.first().json.mime_type || '';\nconst fileType = $input.first().json.file_type || '';\nconst audioData = $input.first().json.audio_data || null;\n\nlet textContent = `РАБОТА СТУДЕНТА:\\n${hwText}`;\nif (audioWarning) textContent += `\\n\\n⚠️ ${audioWarning}`;\n\nconst messagesContent = [{ type: \"text\", text: textContent }];\n\nif (base64Image && mimeType) {\n  messagesContent.push({\n    type: \"image_url\",\n    image_url: { url: `data:${mimeType};base64,${base64Image}` }\n  });\n}\n\nif (audioData && (fileType === 'audio' || fileType === 'video')) {\n  const audioFormat = mimeType.includes('ogg') ? 'ogg' : 'wav';\n  messagesContent.push({\n    type: \"input_audio\",\n    input_audio: { data: audioData, format: audioFormat }\n  });\n}\n\nreturn[{\n  json: { ...$input.first().json, messages_content: messagesContent }\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position":[ 2384, 2480 ],
      "id": "db5f5380-ea46-45ac-b282-30db18893bc3",
      "name": "Prepare AI Messages"
    },
    {
      "parameters": {
        "jsCode": "const studentName = $('Edit Fields').first().json.student_name || 'Студент';\nconst lessonDesc = $('Edit Fields').first().json.lesson_desc || 'Оценить ДЗ';\nconst messagesContent = $input.first().json.messages_content || [];\n\nreturn[{\n  json: {\n    openrouter_request: {\n      model: 'google/gemini-2.5-flash',\n      response_format: { type: 'json_object' },\n      messages:[\n        {\n          role: 'system',\n          content: `Ты мудрый наставник на онлайн-курсе. Имя студента: ${studentName}.\\n\\nКонтекст задания:\\n${lessonDesc}\\n\\nТВОИ ПРАВИЛА:\\n1. Оцени работу. Если есть фото — посмотри, соответствует ли оно заданию.\\n2. Если есть аудио/видео — ИИ может напрямую воспринимать аудио.\\n3. Если работа осмысленная — ставь \"is_approved\": true. Бессмысленная — false.\\n4. Твой \"feedback_text\" должен быть личным, ободряющим.\\n\\nОтвет СТРОГО в формате JSON: {\"is_approved\": boolean, \"feedback_text\": \"string\"}`\n        },\n        {\n          role: 'user',\n          content: messagesContent\n        }\n      ]\n    }\n  }\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [ 2592, 2656 ],
      "id": "1165e267-a2b5-4717-9951-9ca201224f8e",
      "name": "Prepare OpenRouter JSON"
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://openrouter.ai/api/v1/chat/completions",
        "authentication": "predefinedCredentialType",
        "nodeCredentialType": "openRouterApi",
        "sendHeaders": true,
        "headerParameters": {
          "parameters":[
            { "name": "HTTP-Referer", "value": "https://n8n.indikov.ru" },
            { "name": "X-Title", "value": "AntBot Homework Checker" }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ $json.openrouter_request }}",
        "options": { "timeout": 60000 }
      },
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [ 2816, 2656 ],
      "id": "4ce25cfe-d0cb-49d6-ad32-a3d22b878606",
      "name": "OpenRouter AI",
      "retryOnFail": true,
      "maxTries": 3,
      "waitBetweenTries": 2000,
      "credentials": { "openRouterApi": { "id": "BT6u6hYxUcBltOkv", "name": "OpenRouter account" } },
      "onError": "continueErrorOutput"
    },
    {
      "parameters": {
        "jsCode": "try {\n  const rawResponse = $input.first().json.choices[0].message.content;\n  const jsonMatch = rawResponse.match(/(\\{[\\s\\S]*\\})/);\n  \n  if (!jsonMatch || !jsonMatch[1]) throw new Error('Нет JSON в ответе ИИ');\n  const parsedData = JSON.parse(jsonMatch[1]);\n  \n  return { json: { is_approved: parsedData.is_approved, feedback_text: parsedData.feedback_text } };\n} catch (error) {\n  return { json: {\n    is_approved: true,\n    feedback_text: `⚠️ Задание одобрено автоматически из-за технической заминки ИИ. Спасибо! (Ошибка: ${error.message})`\n  }};\n}"
      },
      "type": "n8n-nodes-base.code",
