    {
      "parameters": {
        "jsCode": "const hwText = $input.first().json.hw_text || $('Edit Fields').first().json.hw_text || '[Текст отсутствует]';\nconst studentName = $('Edit Fields').first().json.student_name || 'Студент';\n\nconsole.log(`📝 Текстовое ДЗ от ${studentName}`);\n\nconst messagesContent =[{\n  type: \"text\",\n  text: `РАБОТА СТУДЕНТА:\\n${hwText}`\n}];\n\nreturn[{\n  json: {\n    ...$input.first().json,\n    messages_content: messagesContent\n  }\n}];"
      },
