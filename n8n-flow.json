    {
      "parameters": {
        "jsCode": "// Проверка типа файла и маршрутизация\nconst mimeType = $input.item.json.mimeType || $input.item.json.binary?.data?.mimeType || '';\nconst fileType = mimeType.split('/')[0];\n\nlet output = 0; // 0 = text/no file, 1 = image, 2 = audio, 3 = video\n\nif (mimeType.startsWith('image')) {\n  output = 1;\n} else if (mimeType.startsWith('audio')) {\n  output = 2;\n} else if (mimeType.startsWith('video')) {\n  output = 3;\n}\n\nreturn [{\n  json: {\n    ...$input.item.json,\n    file_type: fileType,\n    mime_type: mimeType,\n    route_output: output\n  }\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -160,
        480
      ],
      "id": "c8f3a9e2-7d4b-4c1e-9f8a-2b5e6d3c4a7f",
      "name": "Route File Type"
    },
    {
      "parameters": {
        "jsCode": "// Ветка ФОТО: конвертация в Base64\nconst binaryData = items[0].binary?.data;\n\nif (!binaryData) {\n  throw new Error('Нет бинарных данных');\n}\n\nconst mimeType = binaryData.mimeType || 'image/jpeg';\nconst fileSize = binaryData.data?.length || 0;\n\nconsole.log(`📸 Фото: ${fileSize} байт, MIME: ${mimeType}`);\n\nitems[0].json.base64_image = binaryData.data;\nitems[0].json.mime_type = mimeType;\nitems[0].json.file_size = fileSize;\nitems[0].json.file_type = 'image';\n\nreturn items;"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        32,
        320
      ],
      "id": "a1b2c3d4-e5f6-7890-abcd-ef1234567890",
      "name": "Process Photo"
    },
    {
      "parameters": {
        "jsCode": "// Ветка АУДИО: проверка размера + сохранение данных\nconst binaryData = items[0].binary?.data;\n\nif (!binaryData) {\n  throw new Error('Нет бинарных данных');\n}\n\nconst mimeType = binaryData.mimeType || 'audio/ogg';\nconst fileSize = binaryData.data?.length || 0;\nconst MAX_AUDIO_SIZE = 10 * 1024 * 1024; // 10 МБ\n\nconsole.log(`🎧 Аудио: ${fileSize} байт (${(fileSize / 1024 / 1024).toFixed(2)} МБ), MIME: ${mimeType}`);\n\nif (fileSize > MAX_AUDIO_SIZE) {\n  console.log(`⚠️ Аудио больше 10 МБ!`);\n  items[0].json.audio_truncated = true;\n  items[0].json.audio_warning = `Аудио слишком большое (${(fileSize / 1024 / 1024).toFixed(2)} МБ). ИИ обработает только часть.`;\n} else {\n  items[0].json.audio_truncated = false;\n}\n\n// Сохраняем binary data для отправки в OpenRouter\nitems[0].json.audio_data = binaryData.data;\nitems[0].json.file_size = fileSize;\nitems[0].json.file_type = 'audio';\nitems[0].json.mime_type = mimeType;\n\nreturn items;"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
