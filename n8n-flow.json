    {
      "parameters": {
        "jsCode": "// Парсинг ответа от OpenRouter\ntry {\n  const rawResponse = $input.item.json.choices[0].message.content;\n  \n  console.log('🤔 Сырой ответ ИИ:', rawResponse.substring(0, 200));\n  \n  const jsonMatch = rawResponse.match(/(\\{[\\s\\S]*\\})/);\n  \n  if (!jsonMatch || !jsonMatch[1]) {\n    throw new Error('Не удалось извлечь JSON из ответа ИИ');\n  }\n  \n  const parsedData = JSON.parse(jsonMatch[1]);\n  \n  if (typeof parsedData.is_approved !== 'boolean') {\n    throw new Error('is_approved должен быть boolean');\n  }\n  \n  if (typeof parsedData.feedback_text !== 'string') {\n    throw new Error('feedback_text должен быть string');\n  }\n  \n  return {\n    json: {\n      is_approved: parsedData.is_approved,\n      feedback_text: parsedData.feedback_text,\n      ai_raw_response: rawResponse\n    }\n  };\n} catch (error) {\n  console.error('❌ Ошибка парсинга:', error.message);\n  \n  return {\n    json: {\n      is_approved: true,\n      feedback_text: `⚠️ Возникла техническая проблема при анализе ИИ, поэтому задание одобрено автоматически. Спасибо за понимание!\\n\\n(Ошибка: ${error.message})`,\n      ai_raw_response: $input.item.json.choices?.[0]?.message?.content || 'Нет ответа',\n      parse_error: true\n    }\n  };\n}"
      },
