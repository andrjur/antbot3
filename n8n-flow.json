      "id": "b2c3d4e5-f6a7-8901-bcde-f12345678901",
      "name": "Process Audio"
    },
    {
      "parameters": {
        "jsCode": "// Ветка ВИДЕО (кружочки/голосовые video/ogg): проверка + сохранение данных\nconst binaryData = items[0].binary?.data;\n\nif (!binaryData) {\n  throw new Error('Нет бинарных данных');\n}\n\nconst mimeType = binaryData.mimeType || 'video/ogg';\nconst fileSize = binaryData.data?.length || 0;\nconst MAX_SIZE = 10 * 1024 * 1024; // 10 МБ\n\nconsole.log(`🎥 Видео/кружочек: ${fileSize} байт (${(fileSize / 1024 / 1024).toFixed(2)} МБ), MIME: ${mimeType}`);\n\nif (fileSize > MAX_SIZE) {\n  console.log(`⚠️ Видео больше 10 МБ!`);\n  items[0].json.file_truncated = true;\n  items[0].json.file_warning = `Файл слишком большой (${(fileSize / 1024 / 1024).toFixed(2)} МБ).`;\n} else {\n  items[0].json.file_truncated = false;\n}\n\n// Сохраняем binary data для отправки в OpenRouter\nitems[0].json.audio_data = binaryData.data; // Gemini принимает аудио из видео как audio_data\nitems[0].json.file_size = fileSize;\nitems[0].json.file_type = 'video';\nitems[0].json.mime_type = mimeType;\n\nreturn items;"
      },
