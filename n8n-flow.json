            {
              "name": "messages",
              "value": "=[\n  {\n    \"role\": \"system\",\n    \"content\": \"Ты мудрый наставник на онлайн-курсе. Имя студента: {{ $('Edit Fields').item.json.student_name }}.\\n\\nКонтекст задания:\\n{{ $('Edit Fields').item.json.lesson_desc }}\\n\\nТВОИ ПРАВИЛА:\\n1. Оцени работу. Если есть фото — посмотри, соответствует ли оно заданию.\\n2. Если есть аудио/видео — ИИ может напрямую воспринимать аудио.\\n3. Если работа осмысленная — ставь \\\"is_approved\\\": true. Бессмысленная — false.\\n4. Твой \\\"feedback_text\\\" должен быть личным, ободряющим, с правильными окончаниями.\\n5. Если студент прислал фото — упомяни конкретные детали.\\n\\nОтвет СТРОГО в формате JSON: {\\\"is_approved\\\": boolean, \\\"feedback_text\\\": \\\"string\\\"}\"\n  },\n  {\n    \"role\": \"user\",\n    \"content\": [\n      {\n        \"type\": \"text\",\n        \"text\": \"РАБОТА СТУДЕНТА:\\n{{ $json.hw_text || $('Edit Fields').item.json.hw_text }}{{ $json.audio_warning ? '\\n\\n⚠️ ' + $json.audio_warning : '' }}{{ $json.file_warning ? '\\n\\n⚠️ ' + $json.file_warning : '' }}\"\n      },\n      {{ $json.base64_image ? '{\"type\": \"image_url\", \"image_url\": {\"url\": \"data:' + $json.mime_type + ';base64,' + $json.base64_image + '\"}}' : 'null' }}\n      {{ $json.file_type === 'audio' || $json.file_type === 'video' ? ', {\"type\": \"input_audio\", \"input_audio\": {\"data\": \"' + ($json.audio_data || '') + '\", \"format\": \"' + ($json.mime_type.includes('ogg') ? 'ogg' : 'wav') + '\"}}' : '' }}\n    ]\n  }\n]"
            }
          ]
        },
        "options": {
